<%= setup_context(:title => t("event._plural")) %>

<div class="d-flex flex-column flex-md-row">
  <div class="col-md-3 order-2 order-md-1">
    <div class="sidebar">
      <%= render_aspace_partial :partial => "search/filter" %>
    </div>
  </div>
  <div class="col-md-9 order-1 order-md-2">
    <% if user_can?('update_event_record') %>
      <%= render :layout => 'shared/record_toolbar' do %>
        <% if user_can?('manage_repository') %>
            <%= link_to I18n.t("actions.edit_default_values"), {:controller => :events, :action => :defaults}, :class => "btn btn-sm btn-default" %>
        <% end %>
        <%= link_to t("actions.export_csv"), request.parameters.merge({ :format => :csv, :fields =>
          fields
          }), id: "searchExport",  class:  "btn btn-sm btn-primary" %>
        <%= link_to t("event._frontend.action.create"), {:controller => :events, :action => :new}, :class => "btn btn-sm btn-default" %>
      <% end %>
    <% end %>

    <div class="record-pane">
      <%= link_to_help :topic => "search" %>

      <h2><%= t("event._plural") %></h2>

      <%= render_aspace_partial :partial => "shared/flash_messages" %>

      <%= render_aspace_partial :partial => "search/listing" %>
    </div>
  </div>
</div>
