<div
  id="infinite-tree-toolbar"
  class="infinite-tree-toolbar btn-toolbar"
  role="toolbar"
  aria-label="<%= I18n.t('tree.toolbar_aria_label', default: 'Tree toolbar') %>"
>
  <!-- Left-aligned groups -->
  <div class="btn-group infinite-tree-toolbar__group" role="group" aria-label="<%= I18n.t('actions.reorder_group', default: 'Reorder and drag/drop') %>">
    <button
      type="button"
      class="btn btn-sm btn-default infinite-tree-toolbar__btn infinite-tree-toolbar__btn--reorder-toggle js-itree-toolbar-reorder-toggle"
      data-itree-action="reorder-toggle"
    >
      <%= I18n.t('actions.enable_reorder') %>
    </button>
  </div>

  <div class="btn-group infinite-tree-toolbar__group ml-1 js-itree-toolbar-cut-paste-group" role="group" aria-label="<%= I18n.t('actions.cut_paste_group', default: 'Cut and paste') %>">
    <button
      type="button"
      class="btn btn-sm btn-default infinite-tree-toolbar__btn js-itree-toolbar-cut"
      data-itree-action="cut"
    >
      <%= I18n.t('actions.cut') %>
    </button>
    <button
      type="button"
      class="btn btn-sm btn-default infinite-tree-toolbar__btn js-itree-toolbar-paste"
      data-itree-action="paste"
    >
      <%= I18n.t('actions.paste') %>
    </button>
  </div>

  <div
    class="btn-group dropdown infinite-tree-toolbar__group ml-1 js-itree-toolbar-move-group"
    role="group"
    aria-label="<%= I18n.t('actions.move_group', default: 'Move node') %>"
  >
    <button
      type="button"
      class="btn btn-sm btn-default dropdown-toggle infinite-tree-toolbar__btn js-itree-toolbar-move-toggle"
      data-toggle="dropdown"
      aria-haspopup="true"
      aria-expanded="false"
      data-itree-action="move-menu"
    >
      <%= I18n.t('actions.move') %>
    </button>
    <ul class="dropdown-menu js-itree-toolbar-move-menu"></ul>
  </div>

  <div
    class="btn-group infinite-tree-toolbar__group ml-2 js-itree-toolbar-expand-group"
    role="group"
    aria-label="<%= I18n.t('actions.expand_collapse_group', default: 'Expand and collapse tree') %>"
  >
    <button
      type="button"
      class="btn btn-sm btn-default infinite-tree-toolbar__btn js-itree-toolbar-expand-mode"
      data-itree-action="expand-mode"
    >
      <%= I18n.t('actions.expand_tree_mode_on') %>
    </button>
    <button
      type="button"
      class="btn btn-sm btn-default infinite-tree-toolbar__btn js-itree-toolbar-collapse-tree"
      data-itree-action="collapse-tree"
    >
      <%= I18n.t('actions.collapse_tree') %>
    </button>
  </div>

  <!-- Per-record-type actions: record-agnostic shell, populated/enabled by JS based on selection/jsonmodel_type -->
  <div
    class="btn-group infinite-tree-toolbar__group ml-2 js-itree-toolbar-primary-actions"
    role="group"
    aria-label="<%= I18n.t('actions.primary_tree_actions', default: 'Primary tree actions') %>"
  >
    <button
      type="button"
      class="btn btn-sm btn-default infinite-tree-toolbar__btn js-itree-toolbar-add-child"
      data-itree-action="add-child"
    >
      <%= I18n.t('resource._frontend.action.add_child') %>
    </button>
    <button
      type="button"
      class="btn btn-sm btn-default infinite-tree-toolbar__btn js-itree-toolbar-add-sibling"
      data-itree-action="add-sibling"
    >
      <%= I18n.t('archival_object._frontend.action.add_sibling') %>
    </button>
    <button
      type="button"
      class="btn btn-sm btn-default infinite-tree-toolbar__btn js-itree-toolbar-add-duplicate"
      data-itree-action="add-duplicate"
    >
      <%= I18n.t('archival_object._frontend.action.add_duplicate') %>
    </button>
    <div
      class="btn-group js-itree-toolbar-load-bulk-group"
      role="group"
      aria-label="<%= I18n.t('resource._frontend.action.load_bulk') %>"
    >
      <button
        type="button"
        class="btn btn-sm btn-default infinite-tree-toolbar__btn border-right-0 js-itree-toolbar-load-bulk"
        data-itree-action="load-bulk"
      >
        <%= I18n.t('resource._frontend.action.load_bulk') %>
      </button>
      <a
        target="_blank"
        class="btn btn-sm btn-default border-left-0 has-tooltip js-itree-load-via-spreadsheet-help"
        id="load_via_spreadsheet_help_icon"
        href="<%= ArchivesSpaceHelp.url_for_topic('resource_load_via_spreadsheet') %>"
        data-toggle="tooltip"
        data-placement="auto"
        title="<%= t('help.topics.resource_load_via_spreadsheet') %>"
        data-container="body"
      >
        <span class="context-help-icon glyphicon glyphicon-question-sign"></span>
      </a>
    </div>
    <button
      type="button"
      class="btn btn-sm btn-default infinite-tree-toolbar__btn js-itree-toolbar-rde"
      data-itree-action="rde"
    >
      <%= I18n.t('actions.rapid_data_entry') %>
    </button>
  </div>

  <!-- Right-aligned Finish Editing -->
  <div
    class="btn-group infinite-tree-toolbar__group ml-auto js-itree-toolbar-finish-group"
    role="group"
  >
    <a
      href="#"
      class="btn btn-sm btn-success infinite-tree-toolbar__btn js-itree-toolbar-finish-editing"
      data-itree-action="finish-editing"
    >
      <%= I18n.t('actions.finish_editing') %>
    </a>
  </div>
</div>
